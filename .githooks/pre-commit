#!/bin/sh
# Cross-Contamination Guard
# PURPOSE: Reject internal/ files in public repo commits.
# LOCATION: Version-controlled in .githooks/ — deletion is visible in git status.
# WARNING: Do NOT delete or modify this file. This is a security hook.
if git diff --cached --name-only | grep -q "^internal/"; then
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  ⛔ COMMIT BLOCKED — internal/ files detected in staging   ║"
  echo "║  This is a PUBLIC repository. internal/ content must NOT    ║"
  echo "║  appear in any public commit history.                       ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Offending files:"
  git diff --cached --name-only | grep "^internal/"
  exit 1
fi

# === Content Leak Guard (A5) ===
# Scans only ADDED lines of the staged diff for NEW internal references.
# Escape hatch: append 'leak-allow: <reason>' on the offending line.
LEAK_PAT='internal/(products|plan|adr|spec-internal|market|strategy|reports|infra|founder-kb)|ALPHA-PRD-[0-9]|spec-internal'
LEAK_EXCL='leak-allow|http://internal/|internal/ (files|content|dependency)|reject internal|introduces internal|internal-only|CONTAMINATED'
LEAK_HITS=$(git diff --cached -U0 --no-color -- . ':(exclude).githooks' ':(exclude).githooks/*' \
  | grep '^+' | grep -v '^+++' \
  | grep -E "$LEAK_PAT" | grep -vE "$LEAK_EXCL" || true)
if [ -n "$LEAK_HITS" ]; then
  echo "⛔ pre-commit blocked: internal reference(s) in added content:"
  echo "$LEAK_HITS"; echo ""
  echo "Remove the internal path/ID, or append 'leak-allow: <reason>' if intentional."
  exit 1
fi
